# Copy this file to .env, then edit the values before running docker compose.

# Required persistent EasyGS home directory on the host.
# It is mounted as /home/easygs/.easygs and stores config.json,
# workspace outputs, resources, history, cron state, etc.
# Use an absolute host path for the least surprising behavior.
EASYGS_HOME_DIR=./easygs-home

# Required data directory mounted into the container as /data.
# Put input files here and refer to them inside EasyGS as /data/...
EASYGS_DATA_DIR=/path/to/your/data

# Default model used by EasyGS. Pick any model supported by your config/provider.
# Examples:
#   anthropic/claude-opus-4-5
#   openai/gpt-4.1
#   deepseek/deepseek-chat
#   openrouter/anthropic/claude-3.5-sonnet
EASYGS_MODEL=anthropic/claude-opus-4-5

# Provider credentials. Fill only the provider(s) you use.
# *_API_BASE is optional unless you use a custom/OpenAI-compatible/local endpoint.
CUSTOM_API_KEY=
CUSTOM_API_BASE=
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=
GROQ_API_KEY=
GROQ_API_BASE=
ZHIPU_API_KEY=
ZHIPU_API_BASE=
DASHSCOPE_API_KEY=
DASHSCOPE_API_BASE=
VLLM_API_KEY=
VLLM_API_BASE=
GEMINI_API_KEY=
GEMINI_API_BASE=
MOONSHOT_API_KEY=
MOONSHOT_API_BASE=
STEPFUN_API_KEY=
STEPFUN_API_BASE=
MINIMAX_API_KEY=
MINIMAX_API_BASE=
AIHUBMIX_API_KEY=
AIHUBMIX_API_BASE=

# Feishu/Lark channel. FEISHU_ALLOW_FROM is a JSON array of allowed open_ids.
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ALLOW_FROM=[]

# Standalone SMTP notification for completed tasks/jobs.
# This is emailOnlyNotify, not the inbound IMAP email channel.
EMAIL_NOTIFY_ENABLED=false
EMAIL_NOTIFY_SMTP_HOST=
EMAIL_NOTIFY_SMTP_PORT=587
EMAIL_NOTIFY_SMTP_USERNAME=
EMAIL_NOTIFY_SMTP_PASSWORD=
EMAIL_NOTIFY_SMTP_USE_TLS=true
EMAIL_NOTIFY_SMTP_USE_SSL=false
EMAIL_NOTIFY_FROM_ADDRESS=
EMAIL_NOTIFY_TO_ADDRESS=
